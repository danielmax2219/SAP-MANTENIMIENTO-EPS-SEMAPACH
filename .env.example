# ===== Configuración SAP Mantenimiento EPS SEMAPACH =====

# Puerto del servidor (opcional, default: 3001)
PORT=3001

# Base de datos PostgreSQL (Supabase)
DATABASE_URL=postgresql://usuario:password@host:5432/postgres

# Secreto para firmar tokens JWT (generar con: openssl rand -hex 32)
JWT_SECRET=changeme_generar_clave_segura_32_bytes_hex

# Orígenes permitidos para CORS (separados por coma)
# Para desarrollo: http://localhost:5173,http://localhost:4173
CORS_ORIGIN=http://localhost:5173,http://localhost:4173

# Email (Gmail) — para notificaciones de registro
EMAIL_USER=tu_correo@gmail.com
EMAIL_PASS=tu_contraseña_app
EMAIL_TO=admin@semapach.pe
